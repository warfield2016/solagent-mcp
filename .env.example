# SolAgent MCP Server Configuration
# Copy this to .env and fill in your values

# Helius API key (free tier: 100K credits/day)
# Get one at https://dev.helius.xyz/
HELIUS_API_KEY=your_helius_api_key_here

# Optional: Custom Solana RPC URL (defaults to Helius if API key set)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Private key for transaction signing (devnet only for demos!)
# SOLANA_PRIVATE_KEY=your_base58_private_key
